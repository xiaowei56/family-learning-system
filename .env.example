# ─── PostgreSQL ──────────────────────────────────────
# 数据库名称
POSTGRES_DB=family_learning
# 数据库用户
POSTGRES_USER=fls_user
# 数据库密码
POSTGRES_PASSWORD=fls_password

# ─── MinIO 对象存储 ─────────────────────────────────
# MinIO 管理员用户名
MINIO_ROOT_USER=fls_minio_admin
# MinIO 管理员密码
MINIO_ROOT_PASSWORD=fls_minio_password

# ─── FastAPI 后端 ────────────────────────────────────
# PostgreSQL 连接字符串（容器内使用服务名 postgres）
DATABASE_URL=postgresql://fls_user:fls_password@postgres:5432/family_learning
# MinIO 服务端点（容器内使用服务名 minio）
MINIO_ENDPOINT=minio:9000
# MinIO Access Key（与 MINIO_ROOT_USER 一致）
MINIO_ACCESS_KEY=fls_minio_admin
# MinIO Secret Key（与 MINIO_ROOT_PASSWORD 一致）
MINIO_SECRET_KEY=fls_minio_password
# MinIO 默认存储桶名称
MINIO_BUCKET_NAME=family-learning-images
# Redis 连接字符串（容器内使用服务名 redis）
REDIS_URL=redis://redis:6379/0
# LLM API 地址（局域网内，非 Docker 内部）
LLM_API_URL=http://192.168.110.7/v1
# JWT 签名密钥
JWT_SECRET=family-learning-jwt-secret-change-in-production
# JWT 签名算法
JWT_ALGORITHM=HS256
# JWT 过期时间（小时）
JWT_EXPIRATION_HOURS=24
# FastAPI 监听地址
SERVER_HOST=0.0.0.0
# FastAPI 监听端口
SERVER_PORT=8000
# 日志级别：debug / info / warning / error
LOG_LEVEL=info
